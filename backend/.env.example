# Copy this file to .env and fill in your values

# PostgreSQL connection string
# For Supabase: postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL="postgresql://postgres:password@localhost:5432/jain_bhojanshala"

# JWT secrets — use long random strings in production
JWT_ACCESS_SECRET="your-access-secret-change-in-production"
JWT_REFRESH_SECRET="your-refresh-secret-change-in-production"

# Token expiry
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS="http://localhost:5173"

# File upload directory (relative to project root)
UPLOAD_DIR="public/uploads"

# Max upload file size in bytes (5 MB default)
MAX_FILE_SIZE="5242880"
