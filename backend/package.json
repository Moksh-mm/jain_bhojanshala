{
  "name": "jain-bhojanshala-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3001",
    "build": "prisma generate && next build",
    "postinstall": "prisma generate",
    "start": "next start --port 3001",
    "lint": "next lint",
    "db:migrate": "prisma migrate dev",
